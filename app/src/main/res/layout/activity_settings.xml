<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <include
        android:id="@+id/topbar"
        layout="@layout/view_topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_appearance_title"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/themeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_item"
                android:padding="8dp">

                <RadioButton
                    android:id="@+id/themeSystem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_system"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="8dp"
                    android:buttonTint="@color/primary" />

                <RadioButton
                    android:id="@+id/themeLight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_light"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="8dp"
                    android:buttonTint="@color/primary" />

                <RadioButton
                    android:id="@+id/themeDark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_dark"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="8dp"
                    android:buttonTint="@color/primary" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_keepalive_title"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_keepalive_desc"
                android:textColor="@color/text_hint"
                android:textSize="13sp"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/modeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_item"
                android:padding="8dp">

                <RadioButton
                    android:id="@+id/radioLite"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_mode_lite"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="8dp"
                    android:buttonTint="@color/primary" />

                <RadioButton
                    android:id="@+id/radioSteady"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_mode_steady"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="8dp"
                    android:buttonTint="@color/primary" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_system_title"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/batteryStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="@string/settings_battery_off"
                android:textColor="@color/text_hint"
                android:textSize="13sp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnBattery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_battery_button"
                android:textColor="@color/on_primary"
                android:background="@drawable/bg_button"
                android:stateListAnimator="@null"
                android:paddingVertical="12dp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnAutostart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_autostart_button"
                android:textColor="@color/text_dark"
                android:background="@drawable/bg_button_tonal"
                android:stateListAnimator="@null"
                android:paddingVertical="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_rom_hint"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_about_title"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/btnAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_about_title"
                android:textColor="@color/text_dark"
                android:textSize="15sp"
                android:background="@drawable/bg_item_ripple"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
