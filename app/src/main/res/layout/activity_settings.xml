<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorScreenBg">

    <include
        android:id="@+id/topbar"
        layout="@layout/view_topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_appearance_title"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/themeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_item"
                android:padding="8dp">

                <RadioButton
                    android:id="@+id/themeSystem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_system"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="8dp"
                    android:buttonTint="?attr/colorPrimary" />

                <RadioButton
                    android:id="@+id/themeLight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_light"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="8dp"
                    android:buttonTint="?attr/colorPrimary" />

                <RadioButton
                    android:id="@+id/themeDark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_dark"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="8dp"
                    android:buttonTint="?attr/colorPrimary" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_color_title"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/colorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_item"
                android:gravity="center"
                android:padding="12dp">

                <FrameLayout
                    android:id="@+id/swatchGrayGreen"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="@string/settings_color_gray_green">
                    <View
                        android:id="@+id/dotGrayGreen"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:background="@drawable/swatch_gg" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/swatchGrayBlue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="@string/settings_color_gray_blue">
                    <View
                        android:id="@+id/dotGrayBlue"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:background="@drawable/swatch_gb" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/swatchLotusPink"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="@string/settings_color_lotus_pink">
                    <View
                        android:id="@+id/dotLotusPink"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:background="@drawable/swatch_lp" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/swatchTerracotta"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="@string/settings_color_terracotta">
                    <View
                        android:id="@+id/dotTerracotta"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:background="@drawable/swatch_tc" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/swatchGrayMauve"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="@string/settings_color_gray_mauve">
                    <View
                        android:id="@+id/dotGrayMauve"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:background="@drawable/swatch_gm" />
                </FrameLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_keepalive_title"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_keepalive_desc"
                android:textColor="@color/text_hint"
                android:textSize="13sp"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/modeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_item"
                android:padding="8dp">

                <RadioButton
                    android:id="@+id/radioLite"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_mode_lite"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="8dp"
                    android:buttonTint="?attr/colorPrimary" />

                <RadioButton
                    android:id="@+id/radioSteady"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_mode_steady"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="8dp"
                    android:buttonTint="?attr/colorPrimary" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_system_title"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/batteryStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="@string/settings_battery_off"
                android:textColor="@color/text_hint"
                android:textSize="13sp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnBattery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_battery_button"
                android:textColor="@color/on_primary"
                android:background="@drawable/bg_button"
                android:stateListAnimator="@null"
                android:paddingVertical="12dp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnAutostart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_autostart_button"
                android:textColor="@color/text_dark"
                android:background="@drawable/bg_button_tonal"
                android:stateListAnimator="@null"
                android:paddingVertical="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_rom_hint"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_about_title"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/btnAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_about_title"
                android:textColor="@color/text_dark"
                android:textSize="15sp"
                android:background="@drawable/bg_item_ripple"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
