<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <include
        android:id="@+id/topbar"
        layout="@layout/view_topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/guide_intro"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="16dp" />

            <!-- 步骤 1 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/guide_step1_title"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/guide_step1_body"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"
                android:background="@drawable/bg_item"
                android:padding="16dp" />

            <ImageView
                android:id="@+id/guideImage1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:layout_marginTop="10dp"
                android:contentDescription="@string/cd_guide_image" />

            <ImageView
                android:id="@+id/guideImage2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:layout_marginTop="10dp"
                android:contentDescription="@string/cd_guide_image" />

            <!-- 步骤 2 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/guide_step2_title"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/guide_step2_body"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"
                android:background="@drawable/bg_item"
                android:padding="16dp" />

            <ImageView
                android:id="@+id/guideImage3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:layout_marginTop="10dp"
                android:contentDescription="@string/cd_guide_image" />

            <!-- 步骤 3 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/guide_step3_title"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/guide_step3_body"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"
                android:background="@drawable/bg_item"
                android:padding="16dp" />

            <Button
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/guide_start"
                android:textColor="@color/text_dark"
                android:background="@drawable/bg_button_tonal"
                android:stateListAnimator="@null"
                android:paddingVertical="12dp"
                android:layout_marginTop="24dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
