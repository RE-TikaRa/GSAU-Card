<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PayCard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_dark</item>
        <item name="colorOnSurfaceVariant">@color/text_hint</item>
        <item name="colorOutline">@color/outline</item>
        <item name="android:windowBackground">@color/screen_bg</item>
        <item name="android:colorBackground">@color/screen_bg</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.PayCard.Dialog</item>
        <item name="android:windowAnimationStyle">@style/Animation.PayCard.Activity</item>
    </style>

    <!-- 付款页跟随主题：浅色白底、深色深底 -->
    <style name="Theme.PayCard.Pay" parent="Theme.PayCard">
        <item name="android:windowBackground">@color/surface</item>
    </style>

    <!-- 统一弹窗外观：圆角、主题色按钮 -->
    <style name="ThemeOverlay.PayCard.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="dialogCornerRadius">24dp</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_dark</item>
    </style>

    <!-- 应用内自定义 Dialog：透明底、居中缩放淡入 -->
    <style name="Dialog.PayCard" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimAmount">0.45</item>
        <item name="android:windowAnimationStyle">@style/Animation.PayCard.Dialog</item>
    </style>

    <style name="Animation.PayCard.Dialog" parent="@android:style/Animation.Dialog">
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>

    <!-- 页面切换：右进左出淡入淡出 -->
    <style name="Animation.PayCard.Activity" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>
</resources>
